# ===== Vercel Postgres =====
# Vercel dashboard'da Postgres oluşturunca otomatik bağlanır
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# ===== Admin =====
# Yeterince uzun ve tahmin edilemez bir string. Örnek: openssl rand -hex 24
ADMIN_KEY=ornek-cok-gizli-anahtar-buraya

# ===== Google Drive OAuth =====
# scripts/get-refresh-token.mjs ile alacaksın (README'de adım adım)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Drive'da oluşturduğun klasörün ID'si (URL'den)
# https://drive.google.com/drive/folders/XXXXXXXXX  <- XXXXX kısmı
DRIVE_FOLDER_ID=
